# Базовый URL БЭКЕНДА (наш FastAPI), а не внешнего сайта вроде https://yandex.ru.
# По умолчанию ПУСТО — фронтенд ходит на тот же origin, а nginx проксирует
# /api/... на бэкенд (штатный режим `make up`). Заполняйте только если бэкенд
# на другом адресе, напр. при локальной разработке: http://127.0.0.1:8000
VITE_API_BASE_URL=

# API-ключ Яндекс Карт для подложки и HTTP-геокодера.
# Если переменная пуста — используется бесплатная подложка OpenStreetMap и
# геокодер Nominatim (≤1 запрос/с, контактный e-mail в User-Agent).
# Лимиты бесплатного плана Яндекса соблюдаются на стороне геокодера:
#   ≤1000 запросов/час и ≤950 запросов/сутки для HTTP-геокодера.
VITE_YANDEX_API_KEY=
