# Пример файла окружения для «Цифрового двойника России».
# Создайте рабочую копию командой `cp .env.example .env` (Windows: `copy .env.example .env`).
# Значений по умолчанию достаточно для локального запуска через `make up` —
# менять их нужно только при подключении внешних источников данных.

# Режим приложения: development | production.
APP_ENV=development
# Хост и порт бэкенда FastAPI внутри контейнера.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Порт, на котором фронтенд доступен в браузере (http://localhost:5173).
FRONTEND_PORT=5173

# Подключение к PostgreSQL/PostGIS. Хост `postgis` — имя сервиса в docker compose.
# При локальном запуске без Docker замените `postgis` на `localhost`.
DATABASE_URL=postgresql+psycopg://digital_twin:digital_twin@postgis:5432/digital_twin
# Подключение к Redis (кеш и очереди). Хост `redis` — имя сервиса в docker compose.
REDIS_URL=redis://redis:6379/0
# S3-совместимое хранилище MinIO. Хост `minio` — имя сервиса в docker compose.
# Консоль MinIO: http://localhost:9001 (логин/пароль — значения ниже).
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=digital_twin
S3_SECRET_KEY=digital_twin_secret
S3_BUCKET=digital-twin-open-contour

# Ключ NASA FIRMS для слоёв пожарной активности (опционально, можно оставить пустым).
# Бесплатный ключ выдаётся здесь: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=
# Регион открытых данных по умолчанию для демо-сценариев.
OPEN_DATA_REGION=Москва
