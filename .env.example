# Пример файла окружения для «Цифрового двойника России».
# Создайте рабочую копию командой `cp .env.example .env` (Windows: `copy .env.example .env`).
# Значений по умолчанию достаточно для локального запуска через `make up` —
# менять их нужно только при подключении внешних источников данных.

# Режим приложения: development | production.
APP_ENV=development
# Хост и порт бэкенда FastAPI внутри контейнера.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Порт, на котором фронтенд доступен в браузере (http://localhost:5173).
FRONTEND_PORT=5173

# Подключение к PostgreSQL/PostGIS. Хост `postgis` — имя сервиса в docker compose.
# При локальном запуске без Docker замените `postgis` на `localhost`.
DATABASE_URL=postgresql+psycopg://digital_twin:digital_twin@postgis:5432/digital_twin
# Подключение к Redis (кеш и очереди). Хост `redis` — имя сервиса в docker compose.
REDIS_URL=redis://redis:6379/0
# S3-совместимое хранилище MinIO. Хост `minio` — имя сервиса в docker compose.
# Консоль MinIO: http://localhost:9001 (логин/пароль — значения ниже).
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=digital_twin
S3_SECRET_KEY=digital_twin_secret
S3_BUCKET=digital-twin-open-contour

# Ключ NASA FIRMS для слоёв пожарной активности (опционально, можно оставить пустым).
# Бесплатный ключ выдаётся здесь: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=
# Регион открытых данных по умолчанию для демо-сценариев.
OPEN_DATA_REGION=Москва

# Ключ API Яндекс Карт для подложки карты (опционально, по умолчанию OSM).
# РЕКОМЕНДУЕМЫЙ способ — задать ключ для БЭКЕНДА переменной YANDEX_API_KEY.
# Бэкенд отдаёт его фронтенду в РАНТАЙМЕ через эндпоинт `/api/v1/config`,
# поэтому достаточно перезапустить контейнер (`make up`) — ПЕРЕСБОРКА не нужна.
# Это исправляет повторявшуюся проблему «кнопка Яндекса неактивна, хотя ключ
# в .env есть» (issue #21).
YANDEX_API_KEY=
# Устаревший способ: Vite «запекает» переменные VITE_* в бандл во время СБОРКИ,
# поэтому после изменения этого ключа фронтенд нужно ПЕРЕСОБРАТЬ. Оставьте
# пустым и используйте YANDEX_API_KEY выше. Подробнее: docs/yandex-basemap.md.
VITE_YANDEX_API_KEY=
# Базовый адрес БЭКЕНДА (FastAPI) для фронтенда. Это НЕ адрес внешнего сайта
# (например, не https://yandex.ru) — сюда подставляется адрес нашего API.
# Оставьте ПУСТЫМ для штатного запуска через `make up`: фронтенд и бэкенд
# доступны на одном origin, а nginx внутри контейнера проксирует `/api/...`
# на бэкенд. Пустое значение = «тот же origin» и подходит большинству.
# Заполняйте, только если фронтенд и бэкенд на РАЗНЫХ адресах, например при
# локальной разработке фронтенда отдельно от Docker:
#   VITE_API_BASE_URL=http://127.0.0.1:8000
# Как и любая VITE_*, переменная «запекается» во время сборки — см.
# docs/yandex-basemap.md (раздел про VITE_API_BASE_URL).
VITE_API_BASE_URL=
